rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated and has an email
    function isAuthenticated() {
      return request.auth != null && 
             request.auth.token != null && 
             request.auth.token.email != null;
    }
    
    // Helper to check if the user is the master admin
    function isMasterAdmin() {
      return request.auth != null && 
             request.auth.token != null && 
             request.auth.token.email == "managementpackaging@gmail.com";
    }
    
    // Helper to check if the user's email exists in allowed_users collection
    function isAllowedUser() {
      return isMasterAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/allowed_users/$(request.auth.token.email))
      );
    }

    // Helper to check if a date's data is verified/locked by the admin
    function isDateLocked(dateStr) {
      return exists(/databases/$(database)/documents/locked_dates/$(dateStr)) &&
             get(/databases/$(database)/documents/locked_dates/$(dateStr)).data.locked == true;
    }

    match /allowed_users/{email} {
      allow read: if isAuthenticated();
      allow write: if isMasterAdmin();
    }

    match /locked_dates/{date} {
      allow read: if request.auth != null;
      allow write: if isMasterAdmin();
    }

    match /laporan_kantong/{id} {
      allow read: if request.auth != null;
      
      // Allow create only if user is allowed and date is not locked (or is master admin)
      allow create: if isAllowedUser() && (
        isMasterAdmin() || 
        !isDateLocked(request.resource.data.tanggal)
      );
      
      // Allow update only if user is allowed and date is not locked (or is master admin)
      allow update: if isAllowedUser() && (
        isMasterAdmin() || 
        !isDateLocked(request.resource.data.tanggal)
      );
      
      // Allow delete only if user is allowed and date is not locked (or is master admin)
      allow delete: if isAllowedUser() && (
        isMasterAdmin() || 
        !isDateLocked(resource.data.tanggal)
      );
    }
  }
}
